  m_Name: barakuda
  m_EditorClassIdentifier: Assembly-CSharp::FishData
  <fishName>k__BackingField: Barakuda
  <fishFact>k__BackingField: "Long, silver, and arrow-straight, the barracuda is
    one of the reef's most feared ambush hunters. They can accelerate from still
    to full sprint in a fraction of a second, using rows of razor-sharp, fang-like
    teeth to tear through prey. Despite their fearsome reputation, barracudas are
    also intensely curious \u2014 they've been known to follow divers around reefs
    for extended periods, which is exactly as unnerving as it sounds."
  <fishImage>k__BackingField: {fileID: 21300000, guid: 7a852a48ca4e64eb78db56c327565f7c, type: 3}
